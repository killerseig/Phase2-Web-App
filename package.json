{
  "name": "phase2",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:e2e": "vite --mode e2e",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "e2e:stack": "firebase emulators:exec --project demo-phase2 --only auth,firestore,functions,storage \"node functions/scripts/run-e2e-stack.mjs\"",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "typecheck": "vue-tsc --noEmit",
    "lint": "npm run typecheck",
    "lint:vue": "eslint \"src/**/*.{ts,vue}\"",
    "lint:ci": "eslint \"src/**/*.{ts,vue}\" --max-warnings 0",
    "lint:all": "npm run lint && npm run lint:ci",
    "check": "npm run lint:all && npm run test -- --run && npm run build"
  },
  "engines": {
    "node": ">=20.19.0",
    "npm": ">=10"
  },
  "dependencies": {
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "firebase": "^12.7.0",
    "flatpickr": "^4.6.13",
    "pinia": "^3.0.4",
    "vue": "^3.5.24",
    "vue-flatpickr-component": "^11.0.3",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^10.0.2",
    "eslint-plugin-vue": "^10.8.0",
    "firebase-tools": "^15.11.0",
    "jsdom": "^28.0.0",
    "sass": "^1.97.3",
    "vite": "^7.2.4",
    "vitest": "^2.1.4",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^2.1.0"
  }
}
