rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /* ---------------- helpers ---------------- */
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function userDoc() {
      return signedIn() ? get(/databases/$(database)/documents/users/$(request.auth.uid)) : null;
    }

    function userDocExists() {
      return userDoc() != null && userDoc().data != null;
    }

    function userRole() {
      return userDocExists() ? userDoc().data.role : null;
    }

    function userIsActive() {
      return userDocExists() && userDoc().data.active == true;
    }

    function roleCanUseApp() {
      return userRole() in ['admin', 'controller', 'foreman'];
    }

    function activeAppUser() {
      return signedIn() && userDocExists() && userIsActive() && roleCanUseApp();
    }

    function userAssignedJobs() {
      return userDocExists() && userDoc().data.assignedJobIds != null
        ? userDoc().data.assignedJobIds
        : [];
    }

    function isAdmin() {
      return activeAppUser() && userRole() == 'admin';
    }

    function isController() {
      return activeAppUser() && userRole() == 'controller';
    }

    function isForemanAssigned(jobId) {
      return activeAppUser() &&
             userRole() == 'foreman' &&
             userAssignedJobs().hasAny([jobId]);
    }

    function hasJobReadAccess(jobId) {
      return activeAppUser() && (
        isAdmin() ||
        (userRole() == 'foreman' && userAssignedJobs().hasAny([jobId]))
      );
    }

    function hasJobWriteAccess(jobId) {
      return activeAppUser() && (
        isAdmin() ||
        (userRole() == 'foreman' && userAssignedJobs().hasAny([jobId]))
      );
    }

    function selfUpdateKeepsPrivileges(uid) {
      return isSelf(uid) &&
             request.resource.data.role == resource.data.role &&
             request.resource.data.active == resource.data.active &&
             request.resource.data.assignedJobIds == resource.data.assignedJobIds;
    }

    function foremanCanMarkTimecardsSent(jobId) {
      return isForemanAssigned(jobId) &&
             request.resource.data.diff(resource.data).changedKeys().hasOnly([
               'timecardStatus',
               'timecardSubmittedAt',
               'timecardPeriodEndDate',
               'timecardLastSentWeekEnding'
             ]) &&
             request.resource.data.timecardStatus == 'submitted' &&
             request.resource.data.timecardSubmittedAt != null &&
             request.resource.data.timecardPeriodEndDate == request.resource.data.timecardLastSentWeekEnding;
    }

    function foremanCanUpdateDailyLogRecipients(jobId) {
      return isForemanAssigned(jobId) &&
             request.resource.data.diff(resource.data).changedKeys().hasOnly(['dailyLogRecipients']);
    }

    function isDraft() {
      return resource.data.status == 'draft';
    }

    /* ---------------- users ---------------- */
    match /users/{uid} {
      // Users can always read their own profile so role/active changes can be applied immediately client-side.
      allow get: if signedIn() && (isSelf(uid) || isAdmin());
      allow list: if isAdmin();

      // Self-create is only allowed as a locked-down role.
      allow create: if isSelf(uid) && request.resource.data.role == 'none';

      // Admins can manage users. Users can update only non-privileged fields on themselves.
      allow update: if isAdmin() || selfUpdateKeepsPrivileges(uid);
      allow delete: if isAdmin();

      match /jobs/{jobId} {
        allow read: if isSelf(uid) || isAdmin();
        allow write: if isAdmin();
      }
    }

    /* ---------------- jobs ---------------- */
    match /jobs/{jobId} {
      allow read: if hasJobReadAccess(jobId) || isController();
      allow create, delete: if isAdmin();
      allow update: if isAdmin() ||
                    foremanCanMarkTimecardsSent(jobId) ||
                    foremanCanUpdateDailyLogRecipients(jobId);

      /* -------- job roster (employees) -------- */
      match /roster/{employeeId} {
        allow read: if hasJobReadAccess(jobId);
        allow create, update, delete: if isAdmin();
      }

      /* -------- job shop orders -------- */
      match /shop_orders/{orderId} {
        allow read: if hasJobReadAccess(jobId);
        allow create, update, delete: if hasJobWriteAccess(jobId);
      }

      /* -------- job daily logs -------- */
      match /dailyLogs/{logId} {
        function isOwnerOfDoc() {
          return signedIn() && resource.data.uid == request.auth.uid;
        }

        allow read: if hasJobReadAccess(jobId) &&
                     (isAdmin() || isOwnerOfDoc());
        allow create: if hasJobWriteAccess(jobId) &&
                      request.resource.data.uid == request.auth.uid &&
                      request.resource.data.status == 'draft' &&
                      request.resource.data.jobId == jobId;
        allow update: if isAdmin() ||
                      (hasJobWriteAccess(jobId) &&
                       isOwnerOfDoc() &&
                       resource.data.status == 'draft' &&
                       request.resource.data.uid == resource.data.uid &&
                       request.resource.data.jobId == resource.data.jobId &&
                       (request.resource.data.status == 'draft' || request.resource.data.status == 'submitted'));
        allow delete: if isAdmin() ||
                      (hasJobWriteAccess(jobId) &&
                       isOwnerOfDoc() &&
                       resource.data.status == 'draft');
      }

      /* -------- job timecards -------- */
      match /timecards/{timecardId} {
        function isOwnerOfDoc() {
          return signedIn() && resource.data.uid == request.auth.uid;
        }

        function fieldsUnchanged() {
          return request.resource.data.jobId == resource.data.jobId &&
                 request.resource.data.employeeRosterId == resource.data.employeeRosterId &&
                 request.resource.data.createdByUid == resource.data.createdByUid &&
                 request.resource.data.uid == resource.data.uid;
        }

        allow read: if (hasJobReadAccess(jobId) && userRole() != 'foreman') ||
                     isController() ||
                     (isForemanAssigned(jobId) && resource.data.createdByUid == request.auth.uid);
        allow create: if isAdmin() ||
                      (isController() &&
                       request.resource.data.status == 'draft' &&
                       request.resource.data.jobId == jobId) ||
                      (hasJobWriteAccess(jobId) &&
                       request.resource.data.uid == request.auth.uid &&
                       request.resource.data.createdByUid == request.auth.uid &&
                       request.resource.data.status == 'draft' &&
                       request.resource.data.jobId == jobId);
        allow update: if isAdmin() ||
                      (isController() &&
                       fieldsUnchanged() &&
                       request.resource.data.status == resource.data.status &&
                       request.resource.data.submittedAt == resource.data.submittedAt) ||
                      (hasJobWriteAccess(jobId) &&
                       isOwnerOfDoc() &&
                       resource.data.status == 'draft' &&
                       fieldsUnchanged() &&
                       (request.resource.data.status == 'draft' || request.resource.data.status == 'submitted'));
        allow delete: if isAdmin() ||
                      (isForemanAssigned(jobId) &&
                       resource.data.createdByUid == request.auth.uid &&
                       resource.data.status == 'draft') ||
                      (isController() && resource.data.status == 'draft');
      }
    }

    /* ---------------- daily logs (legacy, flat collection) ---------------- */
    match /dailyLogs/{logId} {
      allow read, write: if isAdmin();
    }

    /* ---------------- timecards (legacy/dev) ---------------- */
    match /timecards/{timecardId} {
      allow read, write: if isAdmin();
    }

    /* ---------------- nested timecards by week ---------------- */
    match /jobs/{jobId}/weeks/{weekStart}/timecards/{employeeId} {
      function isOwnerOfDoc() {
        return signedIn() && resource.data.uid == request.auth.uid;
      }

      function fieldsUnchanged() {
        return request.resource.data.jobId == resource.data.jobId &&
               request.resource.data.employeeId == resource.data.employeeId &&
               request.resource.data.weekStart == resource.data.weekStart &&
               request.resource.data.weekEnding == resource.data.weekEnding &&
               request.resource.data.uid == resource.data.uid;
      }

      function withinExistingWeek() {
        return resource.data.weekStartTs != null && resource.data.weekEndTs != null &&
               request.time >= resource.data.weekStartTs &&
               request.time <= resource.data.weekEndTs;
      }

      function withinRequestedWeek() {
        return request.resource.data.weekStartTs != null && request.resource.data.weekEndTs != null &&
               request.time >= request.resource.data.weekStartTs &&
               request.time <= request.resource.data.weekEndTs;
      }

      allow read: if hasJobReadAccess(jobId);
      allow create: if isAdmin() ||
                    (hasJobWriteAccess(jobId) &&
                     request.resource.data.uid == request.auth.uid &&
                     request.resource.data.status == 'draft' &&
                     request.resource.data.employeeId == employeeId &&
                     request.resource.data.jobId == jobId &&
                     withinRequestedWeek());
      allow update: if isAdmin() ||
                    (hasJobWriteAccess(jobId) &&
                     isOwnerOfDoc() &&
                     isDraft() &&
                     withinExistingWeek() &&
                     fieldsUnchanged() &&
                     (request.resource.data.status == 'draft' || request.resource.data.status == 'submitted'));
      allow delete: if isAdmin();
    }

    /* ---------------- shop catalog (items with categories) ---------------- */
    match /shopCatalog/{itemId} {
      allow read: if activeAppUser();
      allow write: if isAdmin();
    }

    /* ---------------- shop categories (hierarchical) ---------------- */
    match /shopCategories/{categoryId} {
      allow read: if activeAppUser();
      allow create, update, delete: if isAdmin();
    }

    /* ---------------- settings (app-wide) ---------------- */
    match /settings/{settingId} {
      allow read: if activeAppUser();
      allow write: if isAdmin();
    }

    /* ---------------- shop orders (legacy/dev) ---------------- */
    match /shopOrders/{orderId} {
      allow read, write: if isAdmin();
    }

    /* ---------------- default deny ---------------- */
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
