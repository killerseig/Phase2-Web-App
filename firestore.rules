rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return signedIn()
        ? get(/databases/$(database)/documents/users/$(request.auth.uid))
        : null;
    }

    function userDocExists() {
      return userDoc() != null && userDoc().data != null;
    }

    function userRole() {
      return userDocExists() ? userDoc().data.role : null;
    }

    function userIsActive() {
      return userDocExists() && userDoc().data.active == true;
    }

    function roleCanUseApp() {
      return userRole() in ['admin', 'controller', 'foreman'];
    }

    function activeAppUser() {
      return signedIn() && userDocExists() && userIsActive() && roleCanUseApp();
    }

    function userAssignedJobs() {
      return userDocExists() && userDoc().data.assignedJobIds is list
        ? userDoc().data.assignedJobIds
        : [];
    }

    function isAdmin() {
      return activeAppUser() && userRole() in ['admin', 'controller'];
    }

    function isForemanAssigned(jobId) {
      return activeAppUser() &&
        userRole() == 'foreman' &&
        userAssignedJobs().hasAny([jobId]);
    }

    function hasJobReadAccess(jobId) {
      return activeAppUser() && (
        isAdmin() ||
        isForemanAssigned(jobId)
      );
    }

    function hasJobWriteAccess(jobId) {
      return activeAppUser() && (
        isAdmin() ||
        isForemanAssigned(jobId)
      );
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isOptionalStringOrNull(value) {
      return value == null || value is string;
    }

    function selfCreateHasValidProfileShape() {
      return request.resource.data.keys().hasOnly([
               'email',
               'displayName',
               'firstName',
               'lastName',
               'role',
               'active',
               'assignedJobIds',
               'createdAt'
             ]) &&
             request.resource.data.role == 'none' &&
             request.resource.data.active == true &&
             request.resource.data.createdAt == request.time &&
             (!('email' in request.resource.data) ||
              isOptionalStringOrNull(request.resource.data.email)) &&
             (!('displayName' in request.resource.data) ||
              isOptionalStringOrNull(request.resource.data.displayName)) &&
             (!('firstName' in request.resource.data) ||
              isOptionalStringOrNull(request.resource.data.firstName)) &&
             (!('lastName' in request.resource.data) ||
              isOptionalStringOrNull(request.resource.data.lastName)) &&
             (!('assignedJobIds' in request.resource.data) ||
              (request.resource.data.assignedJobIds is list &&
               request.resource.data.assignedJobIds.size() == 0));
    }

    function selfUpdateKeepsPrivileges(uid) {
      return isSelf(uid) &&
             request.resource.data.role == resource.data.role &&
             request.resource.data.active == resource.data.active &&
             request.resource.data.assignedJobIds == resource.data.assignedJobIds &&
             request.resource.data.diff(resource.data).changedKeys().hasOnly([
               'firstName',
               'lastName'
             ]) &&
             isOptionalStringOrNull(request.resource.data.firstName) &&
             isOptionalStringOrNull(request.resource.data.lastName);
    }

    function foremanCanUpdateDailyLogRecipients(jobId) {
      return isForemanAssigned(jobId) &&
             request.resource.data.diff(resource.data).changedKeys().hasOnly([
               'dailyLogRecipients'
             ]);
    }

    function timecardWeekDoc(weekId) {
      return get(/databases/$(database)/documents/timecardWeeks/$(weekId));
    }

    function timecardWeekExists(weekId) {
      return timecardWeekDoc(weekId).data != null;
    }

    function timecardWeekJobId(weekId) {
      return timecardWeekExists(weekId) ? timecardWeekDoc(weekId).data.jobId : null;
    }

    function timecardWeekIsSubmitted(weekId) {
      return timecardWeekExists(weekId) && timecardWeekDoc(weekId).data.status == 'submitted';
    }

    function foremanCanUpdateTimecardWeek() {
      return hasJobWriteAccess(resource.data.jobId) &&
             resource.data.status == 'draft' &&
             request.resource.data.diff(resource.data).changedKeys().hasOnly([
               'status',
               'employeeCardCount',
               'submittedAt',
               'updatedAt',
               'updatedByUserId',
               'submittedByUserId',
               'submittedByName'
             ]);
    }

    match /users/{uid} {
      allow get: if signedIn() && (isSelf(uid) || isAdmin());
      allow list: if isAdmin();
      allow create: if isSelf(uid) && selfCreateHasValidProfileShape();
      allow update: if isAdmin() || selfUpdateKeepsPrivileges(uid);
      allow delete: if isAdmin();
    }

    match /employees/{employeeId} {
      allow read: if activeAppUser();
      allow create, update, delete: if isAdmin();
    }

    match /jobs/{jobId} {
      allow read: if hasJobReadAccess(jobId);
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || foremanCanUpdateDailyLogRecipients(jobId);
    }

    match /dailyLogs/{logId} {
      allow read: if hasJobReadAccess(resource.data.jobId);
      allow create: if hasJobWriteAccess(request.resource.data.jobId);
      allow update: if isAdmin() ||
                    (hasJobWriteAccess(resource.data.jobId) &&
                     resource.data.status == 'draft' &&
                     request.resource.data.jobId == resource.data.jobId &&
                     request.resource.data.logDate == resource.data.logDate);
      allow delete: if isAdmin() ||
                    (hasJobWriteAccess(resource.data.jobId) &&
                     resource.data.status == 'draft');
    }

    match /timecardWeeks/{weekId} {
      allow read: if hasJobReadAccess(resource.data.jobId);
      allow create: if hasJobWriteAccess(request.resource.data.jobId);
      allow update: if isAdmin() || foremanCanUpdateTimecardWeek();
      allow delete: if isAdmin() ||
                    (hasJobWriteAccess(resource.data.jobId) &&
                     resource.data.status == 'draft');

      match /cards/{cardId} {
        allow read: if timecardWeekExists(weekId) &&
                     hasJobReadAccess(timecardWeekJobId(weekId));
        allow create: if timecardWeekExists(weekId) &&
                       hasJobWriteAccess(timecardWeekJobId(weekId)) &&
                       (isAdmin() || !timecardWeekIsSubmitted(weekId));
        allow update, delete: if timecardWeekExists(weekId) &&
                              hasJobWriteAccess(timecardWeekJobId(weekId)) &&
                              (isAdmin() || !timecardWeekIsSubmitted(weekId));
      }
    }

    match /shopCatalog/{itemId} {
      allow read: if activeAppUser();
      allow create, update, delete: if isAdmin();
    }

    match /shopCategories/{categoryId} {
      allow read: if activeAppUser();
      allow create, update, delete: if isAdmin();
    }

    match /shopOrders/{orderId} {
      allow read: if hasJobReadAccess(resource.data.jobId);
      allow create: if hasJobWriteAccess(request.resource.data.jobId);
      allow update: if isAdmin() ||
                    (hasJobWriteAccess(resource.data.jobId) &&
                     resource.data.status == 'draft' &&
                     request.resource.data.jobId == resource.data.jobId);
      allow delete: if isAdmin() ||
                    (hasJobWriteAccess(resource.data.jobId) &&
                     resource.data.status == 'draft');
    }

    match /settings/{settingId} {
      allow read: if activeAppUser();
      allow write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
