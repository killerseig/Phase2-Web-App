rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return signedIn()
        ? firestore.get(/databases/(default)/documents/users/$(request.auth.uid))
        : null;
    }

    function userDocExists() {
      return userDoc() != null && userDoc().data != null;
    }

    function userRole() {
      return userDocExists() ? userDoc().data.role : null;
    }

    function userIsActive() {
      return userDocExists() && userDoc().data.active == true;
    }

    function activeAppUser() {
      return signedIn() &&
             userDocExists() &&
             userIsActive() &&
             userRole() in ['admin', 'controller', 'foreman'];
    }

    function isAdmin() {
      return activeAppUser() && userRole() in ['admin', 'controller'];
    }

    function dailyLogDoc(logId) {
      return firestore.get(/databases/(default)/documents/dailyLogs/$(logId));
    }

    function dailyLogExists(logId) {
      return dailyLogDoc(logId) != null && dailyLogDoc(logId).data != null;
    }

    function dailyLogOwnerUid(logId) {
      return dailyLogExists(logId) ? dailyLogDoc(logId).data.foremanUserId : null;
    }

    function dailyLogStatus(logId) {
      return dailyLogExists(logId) ? dailyLogDoc(logId).data.status : null;
    }

    function dailyLogJobId(logId) {
      return dailyLogExists(logId) ? dailyLogDoc(logId).data.jobId : null;
    }

    function canReadDailyLogAttachment(logId) {
      return activeAppUser() &&
             dailyLogExists(logId) &&
             (
               isAdmin() ||
               dailyLogOwnerUid(logId) == request.auth.uid
             );
    }

    function canCreateDailyLogAttachment(logId) {
      return activeAppUser() &&
             request.resource != null &&
             request.resource.metadata != null &&
             dailyLogExists(logId) &&
             request.resource.metadata.jobId == dailyLogJobId(logId) &&
             request.resource.metadata.dailyLogId == logId &&
             request.resource.metadata.uploadedBy == request.auth.uid &&
             (
               isAdmin() ||
               (
                 dailyLogOwnerUid(logId) == request.auth.uid &&
                 dailyLogStatus(logId) == 'draft'
               )
             );
    }

    function canDeleteDailyLogAttachment(logId) {
      return activeAppUser() &&
             resource != null &&
             dailyLogExists(logId) &&
             (
               isAdmin() ||
               (
                 dailyLogOwnerUid(logId) == request.auth.uid &&
                 dailyLogStatus(logId) == 'draft'
               )
             );
    }

    match /daily-logs/{logId}/{allPaths=**} {
      allow read: if canReadDailyLogAttachment(logId);
      allow write: if (resource == null && canCreateDailyLogAttachment(logId)) ||
                   (request.resource == null && canDeleteDailyLogAttachment(logId));
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
